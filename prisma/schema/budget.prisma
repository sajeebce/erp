// ═══════════════════════════════════════════
// NGO ERP — Budget Management Models
// Budgets, Budget Lines, Revisions,
// Cost Allocation Rules & Entries
// ═══════════════════════════════════════════

model Budget {
  id                 String           @id @default(uuid()) @db.Uuid
  budgetCode         String           @unique @default("") // Auto-generated: BUD-2026-0001
  name               String
  budgetType         BudgetType       @default(PROJECT)
  projectId          String           @db.Uuid
  grantId            String?          @db.Uuid
  fiscalYearId       String           @db.Uuid
  startDate          DateTime?
  endDate            DateTime?
  periodType         BudgetPeriodType @default(ANNUAL)
  totalAmount        Decimal          @db.Decimal(18, 2)
  currencyCode       CurrencyCode     @default(BDT)
  exchangeRate       Decimal?         @db.Decimal(12, 6) // Fixed exchange rate if applicable
  status             BudgetStatus     @default(DRAFT)
  version            Int              @default(1)

  // Indirect Cost Rate (NICRA)
  indirectCostRate   Decimal?         @db.Decimal(5, 2)  // e.g., 12.50%
  indirectCostBase   IndirectCostBase? // What base to calculate ICR on
  indirectCostAmount Decimal?         @db.Decimal(18, 2) // Auto-calculated ICR amount

  // Cost Sharing / Matching Funds
  costShareRequired  Boolean          @default(false)
  costSharePercent   Decimal?         @db.Decimal(5, 2)  // Required matching %
  costShareAmount    Decimal?         @db.Decimal(18, 2) // Total cost share amount
  donorAmount        Decimal?         @db.Decimal(18, 2) // Donor contribution

  // Controls
  budgetCeiling      Decimal?         @db.Decimal(18, 2) // Donor-imposed maximum
  varianceThreshold  Decimal          @default(10.00) @db.Decimal(5, 2) // % reallocation allowed without approval

  // Narratives
  narrative          String?          @db.Text // Overall budget narrative/justification
  assumptions        String?          @db.Text // Assumptions & basis of estimate

  // Approval
  approvedById       String?          @db.Uuid
  approvedAt         DateTime?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  project            Project          @relation(fields: [projectId], references: [id])
  grant              Grant?           @relation(fields: [grantId], references: [id])
  fiscalYear         FiscalYear       @relation(fields: [fiscalYearId], references: [id])

  lines              BudgetLine[]
  revisions          BudgetRevision[]
  payrollBudgetAllocations PayrollBudgetAllocation[]

  @@index([projectId])
  @@index([grantId])
  @@index([status])
  @@index([budgetType])
  @@index([fiscalYearId])
}

model BudgetLine {
  id             String   @id @default(uuid()) @db.Uuid
  budgetId       String   @db.Uuid
  accountId      String   @db.Uuid
  category       String   // "Personnel", "Operations", "Equipment", "Travel", "Training", "Admin", "M&E", "Contingency"
  subCategory    String?  // e.g., "International Staff", "Local Staff" under Personnel
  description    String
  unit           String?  // e.g., "person", "month", "unit", "lump sum", "trip"
  quantity       Decimal  @default(1) @db.Decimal(10, 2)
  unitCost       Decimal  @db.Decimal(18, 2)
  totalAmount    Decimal  @db.Decimal(18, 2)
  levelOfEffort  Decimal? @db.Decimal(5, 2)  // % for personnel (e.g., 100%, 50%)
  duration       Int?     // Number of months/periods
  donorShare     Decimal? @db.Decimal(18, 2) // Donor-funded portion
  costShare      Decimal? @db.Decimal(18, 2) // Cost share/matching portion
  narrative      String?  @db.Text           // Per-line budget justification (donor requirement)
  notes          String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account        Account  @relation(fields: [accountId], references: [id])

  revisionLines  BudgetRevisionLine[]
  payrollBudgetAllocations PayrollBudgetAllocation[]

  @@index([budgetId])
  @@index([accountId])
  @@index([category])
}

model BudgetRevision {
  id              String         @id @default(uuid()) @db.Uuid
  revisionNo      String         @unique
  budgetId        String         @db.Uuid
  date            DateTime       @default(now())
  originalTotal   Decimal        @db.Decimal(18, 2)
  revisedTotal    Decimal        @db.Decimal(18, 2)
  changeAmount    Decimal        @db.Decimal(18, 2)
  changePercent   Decimal        @db.Decimal(5, 2)
  reason          String
  status          ApprovalStatus @default(DRAFT)
  approvedById    String?        @db.Uuid
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  budget          Budget         @relation(fields: [budgetId], references: [id])
  lines           BudgetRevisionLine[]

  @@index([budgetId])
  @@index([status])
}

model BudgetRevisionLine {
  id               String         @id @default(uuid()) @db.Uuid
  revisionId       String         @db.Uuid
  budgetLineId     String         @db.Uuid
  originalAmount   Decimal        @db.Decimal(18, 2)
  revisedAmount    Decimal        @db.Decimal(18, 2)
  changeAmount     Decimal        @db.Decimal(18, 2)
  reason           String?

  revision         BudgetRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  budgetLine       BudgetLine     @relation(fields: [budgetLineId], references: [id])

  @@index([revisionId])
}

model CostAllocationRule {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  totalAmount  Decimal   @db.Decimal(18, 2)
  isActive     Boolean   @default(true)
  frequency    String    @default("MONTHLY")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  entries      CostAllocationEntry[]
}

model CostAllocationEntry {
  id              String             @id @default(uuid()) @db.Uuid
  ruleId          String             @db.Uuid
  projectId       String             @db.Uuid
  percentage      Decimal            @db.Decimal(5, 2)
  allocatedAmount Decimal            @db.Decimal(18, 2)
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime           @default(now())

  rule            CostAllocationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  project         Project            @relation(fields: [projectId], references: [id])

  @@index([ruleId])
  @@index([projectId])
}
